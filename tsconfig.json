{
  "extends": "astro/tsconfigs/strict",
  "include": [
    ".astro/types.d.ts",
    "**/*"
  ],
  "exclude": [
    "dist"
  ],
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./src/*"
      ]
    },
    "jsx": "preserve",
    "jsxImportSource": "preact"
  },
  "paths": {
    "@components/*": [
      "./src/components/*"
    ],
    "@assets/*": [
      "./src/assets/*"
    ],
    "@content/*": [
      "./src/content/*"
    ]
  }
}