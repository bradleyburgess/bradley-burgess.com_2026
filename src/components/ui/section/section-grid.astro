---
import type { HTMLAttributes } from "astro/types";
import { cva, type VariantProps } from "class-variance-authority";

import { cn } from "@/lib/utils";

interface Props extends HTMLAttributes<"div">, VariantProps<typeof variants> {}

const variants = cva("grid w-full gap-6", {
  variants: {
    frame: {
      default: "",
    },
    size: {
      xs: "grid-cols-[repeat(auto-fill,minmax(140px,1fr))]",
      sm: "grid-cols-[repeat(auto-fill,minmax(200px,1fr))]",
      md: "grid-cols-1 @sm:grid-cols-[repeat(auto-fill,minmax(240px,1fr))]",
      default: "grid-cols-1 @sm:grid-cols-[repeat(auto-fill,minmax(260px,1fr))]",
      lg: "grid-cols-1 @sm:grid-cols-[repeat(auto-fill,minmax(400px,1fr))]",
      xl: "grid-cols-1 @sm:grid-cols-[repeat(auto-fill,minmax(600px,1fr))]",
    },
  },
  defaultVariants: {
    size: "default",
    frame: "default",
  },
});

const { class: className, size, frame, ...props } = Astro.props;
---

<div class={cn(variants({ size, frame }), className)} {...props}>
  <slot />
</div>
