---
import { Image } from "astro:assets";
import {
  Tile,
  TileContent,
  TileDescription,
  TileMedia,
  TileTitle,
} from "@/components/ui/tile";
import { marked } from "marked";
import { formatDate } from "@/lib/utils";
import { SectionGrid } from "../ui/section";

interface Props {
  posts: {
    href: string;
    title: string;
    description: string;
    publishDate: string;
    image: {
      src: ImageMetadata;
      alt: string;
      width?: number;
      height?: number;
    };
  }[];
}

const { posts } = Astro.props;
---

<div class="w-full flex flex-col gap-4 lg:gap-6">
  <SectionGrid size="sm">
    <!-- <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4 lg:gap-6 xl:gap-8"> -->
    {
      posts?.map(({ title, description, image, href, publishDate }) => (
        <Tile href={href}>
          <TileMedia class="aspect-video w-full">
            <Image fit="cover" layout="full-width" {...image} />
          </TileMedia>
          <TileContent>
            <TileTitle class="leading-tight">{title}</TileTitle>
            <TileDescription>{formatDate(publishDate)}</TileDescription>
            <TileDescription set:html={marked(description!)} />
          </TileContent>
        </Tile>
      ))
    }
    <!-- </div> -->
  </SectionGrid>
</div>
