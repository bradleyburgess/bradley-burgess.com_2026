---
import "@/styles/global.css";
import { getEntry } from "astro:content";
import { SEO, type TwitterCardType } from "astro-seo";
import Header from "@/components/blocks/header-2.astro";
import Footer from "@/components/Footer.astro";
import { getImage } from "astro:assets";

interface Props {
  title?: string;
  description?: string;
  type?: "article" | "website";
  publishedTime?: string;
  tags?: string[];
  ogImage?: {
    src: ImageMetadata;
    alt: string;
  };
}

interface OpenGraph {
  basic: {
    title: string;
    type: string;
    image: string;
    url?: URL | string;
  };
  optional?: {
    audio?: string;
    description?: string;
    determiner?: string;
    locale?: string;
    localeAlternate?: string[];
    siteName?: string;
    video?: string;
  };
  image?: {
    url?: URL | string;
    secureUrl?: URL | string;
    type?: string;
    width?: number;
    height?: number;
    alt?: string;
  };
  article?: {
    publishedTime?: string;
    modifiedTime?: string;
    expirationTime?: string;
    authors?: string[];
    section?: string;
    tags?: string[];
  };
  twitter?: {
    card?: TwitterCardType;
    site?: string;
    creator?: string;
    title?: string;
    description?: string;
    image?: URL | string;
    imageAlt?: string;
  };
}

const config = await getEntry("config", "site-config");

const {
  title: propTitle,
  description: propDescription,
  ogImage: propOgImage,
  type = "website",
  publishedTime,
  tags,
} = Astro.props;
const title = propTitle
  ? `${propTitle} | ${config?.data.shortTitle}`
  : config?.data.title;

const description = propDescription ?? config?.data.description;
const ogImage = propOgImage ?? config!.data.defaultOgImage;

const transformedImage = await getImage({
  src: ogImage.src,
  width: 1200,
  height: 630,
  format: "jpg",
  quality: 80,
});

const openGraph: OpenGraph = {
  basic: {
    title: propTitle ?? title!,
    type,
    image: new URL(transformedImage.src, Astro.site).toString(),
  },
  optional: {
    description,
  },
  image: {
    alt: ogImage.alt,
  },
  twitter: {
    card: "summary_large_image",
    title: propTitle ?? title!,
    description,
    image: new URL(transformedImage.src, Astro.site).toString(),
    imageAlt: ogImage.alt,
  },
};
if (type === "article") {
  openGraph!.article = {
    publishedTime,
    tags,
  };
}

const links = config?.data.navLinks.map((link) => ({
  text: link.label,
  href: link.to,
  icon: link.icon,
}));
---

<!doctype html>
<html lang="en" class="min-h-screen">
  <head>
    <SEO
      charset="UTF-8"
      title={title}
      description={description}
      canonical={Astro.url.href}
      openGraph={openGraph}
      extend={{
        link: [
          { rel: "icon", href: "/favicon.svg" },
          { rel: "sitemap", href: "/sitemap-index.xml" },
          { rel: "alternate", type: "application/rss+xml", href: "/rss.xml" },
        ],
        meta: [
          {
            name: "viewport",
            content: "width=device-width, initial-scale=1.0",
          },
        ],
      }}
    />
    <style is:global>
      [data-usal]:not(.initialized) {
        opacity: 0;
        visibility: hidden;
      }
    </style>
  </head>
  <body class="@container min-h-screen flex flex-col">
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:absolute focus:top-0 focus:left-0 focus:p-4 focus:z-10 focus:text-foreground"
      >Skip to main content</a
    >
    <Header menus={links} />
    <main class="flex-1" id="main">
      <slot />
    </main>
    <Footer />
    <script
      is:inline
      src="https://unpkg.com/usal@1.3.1/usal.min.js"
      integrity="sha384-gNUEWGXTWy8IgE1qJlVEHhLWPgOWEtlR1J71iDS013BXtaPBpwmKSS5yLFd4dP6r"
      crossorigin="anonymous"></script>
    <script>
      (function () {
        // Add 'initialized' synchronously after USAL registers its requestAnimationFrame
        // but before it fires. USAL then captures the correct natural styles (opacity: 1)
        // and applies its own start keyframe in the same rAF — no FOUC, no race condition.
        document.querySelectorAll("[data-usal]").forEach(function (el) {
          el.classList.add("initialized");
        });
      })();
    </script>
    <script
      is:inline
      src="https://unpkg.com/dayjs@1.11.20/dayjs.min.js"
      integrity="sha384-DpVxUeeBWjUvUV1czyIHJAjh+jYUZFu2lLakbdua5vbwOrBGi1UgaKCHjTC+x3Ky"
      crossorigin="anonymous"></script>
    <script
      is:inline
      src="https://unpkg.com/dayjs@1.11.20/plugin/relativeTime.js"
      integrity="sha384-ssUzPQXjLHLO39a9AiuwxnnyDxIvOMUxEQpqfreUaW7jLEdDAXiF6UooZRO53F6Z"
      crossorigin="anonymous"></script>
    <script>
      interface WindowWithDayjs extends Window {
        dayjs: any;
        dayjs_plugin_relativeTime: any;
      }

      (function () {
        const w = window as unknown as WindowWithDayjs;
        if (w.dayjs) {
          w.dayjs.extend(w.dayjs_plugin_relativeTime);
        }
      })();
    </script>
  </body>
</html>
