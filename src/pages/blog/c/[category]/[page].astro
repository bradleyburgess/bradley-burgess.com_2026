---
import BlogListLayout from "@/layouts/BlogListLayout.astro";
import { getAllTags, titleCase } from "@/lib/utils";
import type { GetStaticPaths } from "astro";
import { getCollection } from "astro:content";

export const getStaticPaths = (async ({ paginate }) => {
  const allCategories = await getCollection("blogCategories").then(
    (categories) => categories.map((cat) => cat.data),
  );
  const allPosts = await getCollection("blog").then((posts) =>
    posts.sort((a, b) => {
      const dateA = new Date(a.data.publishDate);
      const dateB = new Date(b.data.publishDate);
      return dateB.getTime() - dateA.getTime();
    }),
  );
  const paths = allCategories.flatMap((cat) =>
    paginate(
      allPosts.filter((post) => post.data.category === cat.id),
      {
        params: { category: cat.id },
        pageSize: 10,
      },
    ),
  );
  return paths;
}) satisfies GetStaticPaths;

const blogPage = (await getCollection("blogPage"))[0]?.data;
if (!blogPage) throw new Error("Blog page config not found");

const allTags = await getCollection("blog").then((posts) =>
  getAllTags(posts.map((p) => p.data)),
);

const allCategories = (await getCollection("blogCategories")).map(
  (cat) => cat.data,
);
if (!allCategories) throw new Error("Blog categories not found");

const { page } = Astro.props;
const { category } = Astro.params;
---

<BlogListLayout
  title={`${titleCase(category)} Posts`}
  description={blogPage.description ??
    `All posts in the ${titleCase(category)} category`}
  page={page}
  categories={allCategories}
  tags={allTags}
  activeCategory={category}
  showShowAll={true}
/>
